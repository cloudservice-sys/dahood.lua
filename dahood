-- Hitbox Expander
-- ─────────────────────────────────────────────
local hitboxExpanderEnabled = false
local hitboxSize   = 10
local hitboxColor  = Color3.new(0,1,1)
local visualizeHitbox = false
local HBEClient = LocalPlayer

local function removeHitboxVisuals(Character)
    if not Character then return end
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if HRP then
        local o = HRP:FindFirstChild("HitboxOutline") if o then o:Destroy() end
        local g = HRP:FindFirstChild("HitboxGlow") if g then g:Destroy() end
    end
end
local function resetHitboxCharacter(Character)
    if not Character then return end
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if HRP then HRP.Size=Vector3.new(2,1,2) HRP.Transparency=1 HRP.CanCollide=true removeHitboxVisuals(Character) end
end
local function handleHitboxCharacter(Character)
    if not Character or not hitboxExpanderEnabled then resetHitboxCharacter(Character) return end
    local HRP = Character:FindFirstChild("HumanoidRootPart") or Character:WaitForChild("HumanoidRootPart",5)
    if not HRP then return end
    HRP.Size=Vector3.new(hitboxSize,hitboxSize,hitboxSize) HRP.Transparency=1 HRP.CanCollide=false
    if visualizeHitbox then
        local outline = HRP:FindFirstChild("HitboxOutline")
        if not outline then
            outline = Instance.new("BoxHandleAdornment") outline.Name="HitboxOutline" outline.Adornee=HRP
            outline.Size=HRP.Size outline.Transparency=0.8 outline.ZIndex=10 outline.AlwaysOnTop=true outline.Color3=hitboxColor outline.Parent=HRP
            local glow = Instance.new("BoxHandleAdornment") glow.Name="HitboxGlow" glow.Adornee=HRP
            glow.Size=HRP.Size+Vector3.new(0.1,0.1,0.1) glow.Transparency=0.9 glow.ZIndex=9 glow.AlwaysOnTop=true glow.Color3=hitboxColor glow.Parent=HRP
        else
            outline.Size=HRP.Size outline.Color3=hitboxColor
            local glow = HRP:FindFirstChild("HitboxGlow") if glow then glow.Size=HRP.Size+Vector3.new(0.1,0.1,0.1) glow.Color3=hitboxColor end
        end
    else removeHitboxVisuals(Character) end
end
local function handleHitboxPlayer(Player)
    if Player==HBEClient then return end
    Player.CharacterAdded:Connect(function(Character) Character:WaitForChild("HumanoidRootPart") handleHitboxCharacter(Character) end)
    if Player.Character then handleHitboxCharacter(Player.Character) end
end
for _,p in pairs(Players:GetPlayers()) do handleHitboxPlayer(p) end
Players.PlayerAdded:Connect(handleHitboxPlayer)
RunService.Heartbeat:Connect(function()
    for _,p in pairs(Players:GetPlayers()) do
        if p~=HBEClient and p.Character then
            if hitboxExpanderEnabled then handleHitboxCharacter(p.Character)
            else resetHitboxCharacter(p.Character) end
        end
    end
end)

