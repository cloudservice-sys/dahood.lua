        end
        -- Tracers
        for _,t in pairs(drawingTracers) do t:Remove() end drawingTracers={}
        local targetsForVisual = multiTargetEnabled and targetlist or {lockedTarget}
        for _,tgt in ipairs(targetsForVisual) do
            local tPart = tgt.Character and tgt.Character:FindFirstChild(targetHitPart)
            if TracerEnabled and tPart then
                local tracer2 = Drawing.new("Line")
                tracer2.Visible = true tracer2.Thickness = 1 tracer2.Color = tracerColor
                local tScreenPos, onScreen = Camera:WorldToViewportPoint(tPart.Position)
                local endPos
                if targetToMouseTracer then
                    endPos = UserInputService:GetMouseLocation()
                else
                    local rp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if rp then local rsp, ron = Camera:WorldToViewportPoint(rp.Position) if ron then endPos = Vector2.new(rsp.X,rsp.Y) end end
                end
                if onScreen and endPos then tracer2.From=Vector2.new(tScreenPos.X,tScreenPos.Y) tracer2.To=endPos else tracer2.Visible=false end
                table.insert(drawingTracers, tracer2)
            end
        end
        -- Hitsound on damage
        local humanoid = lockedTarget.Character:FindFirstChild("Humanoid")
        if humanoid then
            if not getgenv().lastHealth[lockedTarget.Name] then getgenv().lastHealth[lockedTarget.Name] = humanoid.Health end
            if humanoid.Health < getgenv().lastHealth[lockedTarget.Name] then playHitsound() end
            getgenv().lastHealth[lockedTarget.Name] = humanoid.Health
        end
        -- Strafe bail-outs
        if strafeEnabled and lockedTarget and (lockedTarget.Character:FindFirstChildOfClass("ForceField") or isSDeath or (isKO and not stompTargetEnabled)) then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(math.random(-1111,1111),math.random(0,1111),math.random(-1111,1111)) return end
        if strafeEnabled and lockedTarget and isKO and stompTargetEnabled then return end
        -- Strafe
        if strafeEnabled and targetPart and not isGrabbed then
            if autoEquipGunsEnabled then autoEquipAllGuns() end
            checkVoid()
            local targetRoot = lockedTarget.Character:FindFirstChild("HumanoidRootPart")
            local targetPosition = targetRoot.Position
            if predictMovementEnabled then targetPosition = predictPosition(targetRoot, PredicTvalue) end
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").PlatformStand = true
            if strafeMode == "Random" then
                local offset = Vector3.new(math.random(-15,15),math.random(-15,15),math.random(-15,15))
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPosition+offset)
            end
        else
            if LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                LocalPlayer.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false end
        end
        -- Auto-shoot
        local tool   = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        local handle = tool and tool:FindFirstChild("Handle")
        local targetsForShoot = multiTargetEnabled and targetlist or {lockedTarget}
        for _,tgt in ipairs(targetsForShoot) do
            local tPart = tgt.Character and tgt.Character:FindFirstChild(targetHitPart)
            local tCh   = tPart and tPart:FindFirstAncestorOfClass("Model")
            local tBE   = tCh and tCh:FindFirstChild("BodyEffects")
            local tKO   = tBE and tBE:FindFirstChild("K.O") and tBE["K.O"].Value
            local tGrab = tCh and tCh:FindFirstChild("GRABBING_CONSTRAINT")
            local tFF   = tCh and tCh:FindFirstChildOfClass("ForceField")
            if tool and handle and tPart and not tKO and not tGrab and not tFF then
                local pp = getPredictedPosition(tPart)
                if hiddenBulletsEnabled then
                    ReplicatedStorage.MainEvent:FireServer("ShootGun", handle, handle.CFrame.Position-Vector3.new(0,10,0), pp-Vector3.new(0,10,0), tPart, Vector3.new(0,0,-1))
                else
                    ReplicatedStorage.MainEvent:FireServer("ShootGun", handle, handle.CFrame.Position, pp, tPart, Vector3.new(0,0,-1))
                end
            end
        end
    else
        if strafeEnabled and oldPosition then LocalPlayer.Character.HumanoidRootPart.CFrame = oldPosition oldPosition=nil end
        for _,t in pairs(drawingTracers) do t:Remove() end drawingTracers={}
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false end
    end
end)

